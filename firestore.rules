rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default block all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Main collection: Prescriptions
    match /prescriptions/{prescriptionId} {
      allow read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && isValidPrescription(request.resource.data);
        
      allow update: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid)
        && request.resource.data.userId == request.auth.uid
        && isValidPrescription(request.resource.data);
    }

    // 3. Main collection: PioKie Logs
    match /pio_kie/{recordId} {
      allow read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && isValidPioKie(request.resource.data);
        
      allow update: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid)
        && request.resource.data.userId == request.auth.uid
        && isValidPioKie(request.resource.data);
    }

    // --- REUSABLE UTILITIES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidPioKie(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.nomorDokumentasi is string && data.nomorDokumentasi.size() <= 100
        && data.jenisDokumentasi is string && (data.jenisDokumentasi == "PIO" || data.jenisDokumentasi == "KIE")
        && data.date is string && data.date.size() == 10
        && data.namaPasien is string && data.namaPasien.size() <= 200
        && data.jenisKelamin is string && (data.jenisKelamin == "Laki-laki" || data.jenisKelamin == "Perempuan")
        && data.keluhanPertanyaan is string && data.keluhanPertanyaan.size() <= 10000
        && data.jawabanTindakLanjut is string && data.jawabanTindakLanjut.size() <= 10000
        && data.metode is string && (data.metode == "Tatap Muka" || data.metode == "Telepon" || data.metode == "Video Call")
        && data.namaApoteker is string && data.namaApoteker.size() <= 200
        && (!("umur" in data) || (data.umur is string && data.umur.size() <= 50))
        && (!("beratBadan" in data) || (data.beratBadan is string && data.beratBadan.size() <= 50))
        && (!("hamilMenyusui" in data) || (data.hamilMenyusui is string && data.hamilMenyusui.size() <= 200))
        && (!("riwayatAlergi" in data) || (data.riwayatAlergi is string && data.riwayatAlergi.size() <= 200))
        && (!("referensi" in data) || (data.referensi is string && data.referensi.size() <= 500));
    }

    function isValidPrescription(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.date is string && data.date.size() == 10
        && data.medicines is list
        && data.medicines.size() >= 0 && data.medicines.size() <= 100
        && (!('doctor' in data) || (data.doctor is string && data.doctor.size() <= 200))
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000))
        && (!('prescriptionNo' in data) || (data.prescriptionNo is string && data.prescriptionNo.size() <= 100))
        && (!('patientName' in data) || (data.patientName is string && data.patientName.size() <= 200))
        && (!('patientAddress' in data) || (data.patientAddress is string && data.patientAddress.size() <= 1000));
    }
  }
}
